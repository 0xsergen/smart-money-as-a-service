# Quicknode SQL Explorer REST API key. If omitted, the app uses fixture data.
QUICKNODE_API_KEY=

# Quicknode Hyperliquid endpoint used by @quicknode/hyperliquid-sdk for selected-wallet enrichment.
QUICKNODE_HYPERLIQUID_RPC_URL=

# Optional token used to verify Quicknode webhook deliveries.
# Configure the same value as the webhook security token in Quicknode.
QN_WEBHOOK_SECURITY_TOKEN=

# Secret used by Vercel Cron/protected job routes.
CRON_SECRET=

# Turso/libSQL database used to persist normalized webhook events.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Official x402 paid public API settings for /api/paid/*.
X402_PAY_TO_ADDRESS=
X402_PRICE_USD="$0.01"
X402_NETWORK="eip155:84532"
X402_FACILITATOR_URL="https://x402.org/facilitator"

# Optional overrides.
SMART_MONEY_MIN_VOLUME_USD=1000000
SMART_MONEY_LIMIT=50
SMART_MONEY_WATCHLIST_NAME=smart-money-wallets
LEADERBOARD_CACHE_TTL_MS=60000
WALLET_PROFILE_CACHE_TTL_MS=60000
ALLOW_UNLISTED_WALLET_PROFILES=0
